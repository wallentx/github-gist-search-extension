{
  "manifest_version": 3,
  "name": "GitHub Gist Enhanced Search",
  "version": "0.1.0",
  "description": "Adds qualifier suggestions and autocomplete to the GitHub Gist search bar.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://gist.github.com/*"],
      "js": ["content-script.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
